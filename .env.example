# Do not commit .env or real API keys.

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

VISION_API_KEY=your_qwen_vision_api_key_here
